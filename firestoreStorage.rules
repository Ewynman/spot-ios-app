rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Spot images
    match /spots/{file} {
      // Anyone can view images
      allow read: if true;
      // Any authenticated user can upload/delete (app enforces ownership at Firestore layer)
      allow write: if request.auth != null;
    }

    // Profile pictures
    match /profile_pictures/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else: denied
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}