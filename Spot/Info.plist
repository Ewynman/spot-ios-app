<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>Spot uses your camera to take photos of your spots</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Spot uses your photo library to select photos for your spots</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Spot uses your location to show nearby spots and add your spot to the map</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Spot sends you alerts about new spots nearby</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.spotapp.spot</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>spotapp</string>
			</array>
		</dict>
	</array>
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
</dict>
</plist>
