rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // Users and their subcollections
    // ============================
    match /users/{userId} {
      // Allow reading any user's basic public data (but respect privacy for sensitive info)
      allow read: if true;

      // Allow user to modify their own profile document
      allow write: if request.auth != null && request.auth.uid == userId;

      // User subcollections (collections, followRequests, followers)
      match /{subpath=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================
    // Spots collection - WITH PRIVACY
    // ============================
    match /spots/{spotId} {
      // Public spots: anyone can read
      allow read: if resource.data.get("authorIsPrivate", false) == false;
      
      // Private spots: only followers can read
      allow read: if resource.data.get("authorIsPrivate", false) == true && 
                     request.auth != null && 
                     exists(/databases/$(database)/documents/users/$(resource.data.userId)/followers/$(request.auth.uid));

      // Create: authenticated users can create their own spots
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Update: owner can update anything, authenticated users can update saves/likes counters
      allow update: if request.auth != null && (
        // Owner can update anything
        request.auth.uid == resource.data.userId ||
        // Authenticated users can update saves/likes counters for bookmarking/liking
        // Ensure userId and other critical fields don't change, only saves/likes can be updated
        (request.resource.data.userId == resource.data.userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['saves']) &&
         request.resource.data.saves is int) ||
        (request.resource.data.userId == resource.data.userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
         request.resource.data.likes is int) ||
        (request.resource.data.userId == resource.data.userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['saves', 'likes']) &&
         request.resource.data.saves is int &&
         request.resource.data.likes is int)
      );

      // Delete: only owner can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ============================
    // Global Vibe Tags
    // ============================
    match /vibeTags/{tagId} {
      // Anyone can read available tags
      allow read: if true;
      // Authenticated users can create new tags
      allow create: if request.auth != null;
      // No client updates/deletes for now
      allow update, delete: if false;
    }

    // ============================
    // Places collection
    // ============================
    match /places/{placeId} {
      // Anyone can read
      allow read: if true;
      // Only authenticated users may create or update
      allow write: if request.auth != null;
    }

    // ============================
    // Follow Requests - PRIVATE
    // ============================
    match /users/{userId}/followRequests/{requesterId} {
      // Only the target user can read their own follow requests
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only the requester can create, target user can update/delete
      allow write: if request.auth != null && (request.auth.uid == requesterId || request.auth.uid == userId);
    }

    // ============================
    // Followers - PRIVATE
    // ============================
    match /users/{userId}/followers/{followerId} {
      // Only the user can read their own followers list
      allow read: if request.auth != null && request.auth.uid == userId;
      // Only system operations should modify followers (managed server-side)
      allow write: if false; // Use Cloud Functions for follower management
    }

    // ============================
    // Subscription Sessions - SECURE TOKENS
    // ============================
    match /subscriptionSessions/{sessionId} {
      // No client-side reads allowed (web backend uses Admin SDK)
      allow read: if false;
      
      // Authenticated users can create session tokens for themselves
      // action field is optional (for manage vs subscribe)
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid &&
                     request.resource.data.keys().hasAll(['userId', 'email', 'username', 'returnUrl', 'createdAt', 'expiresAt']) &&
                     (!('action' in request.resource.data) || request.resource.data.action is string);
      
      // Users can delete their own session tokens (for cleanup)
      // Web backend will also delete via Admin SDK
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
      
      // No updates allowed (tokens are immutable)
      allow update: if false;
    }
  }
}