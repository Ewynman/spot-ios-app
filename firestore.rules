rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================
    // Users and their subcollections
    // ============================
    match /users/{userId} {
      // Allow reading any user's public data
      allow read: if true;

      // Allow user to modify their own profile document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Allow the same user to read/write any nested subcollection
      match /{subpath=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================
    // Spots collection
    // ============================
    match /spots/{spotId} {
      // Anyone can read spots
      allow read: if true;

      // Create or update: user can only manage their own spots
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Delete: only owner can delete
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      // Optional: if you have subcollections under each spot (e.g. comments)
      match /{subpath=**} {
        allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }

    // ============================
    // Global Vibe Tags
    // ============================
    match /vibeTags/{tagId} {
      // Anyone can read available tags
      allow read: if true;
      // Authenticated users can create new tags
      allow create: if request.auth != null;
      // No client updates/deletes for now
      allow update, delete: if false;
    }

    // ============================
    // Places collection
    // ============================
    match /places/{placeId} {
      // Anyone can read
      allow read: if true;

      // Only authenticated users may create or update
      allow write: if request.auth != null;
    }
  }
}
