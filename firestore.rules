rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if {viewer} follows {owner}
    function isFollower(viewer, owner) {
      // The app maintains an array field users/{viewer}.following: [ownerId]
      // This helper returns true when viewer is following owner.
      // If your graph stores followers as subcollection instead, mirror accordingly.
      return exists(/databases/$(database)/documents/users/$(viewer)) &&
             get(/databases/$(database)/documents/users/$(viewer)).data.following.hasAny([owner]);
    }

    match /spots/{spotId} {
      allow read: if isSpotReadable();
      allow list: if false; // rely on per-doc checks via queries

      function isSpotReadable() {
        let data = resource.data;
        let owner = data.authorId != null ? data.authorId : data.userId; // backward compatibility
        let isPrivate = data.authorIsPrivate == true;
        // Always allow owner
        if (request.auth != null && request.auth.uid == owner) {
          return true;
        }
        // Public author
        if (!isPrivate) {
          return true;
        }
        // Private author: allowed only if viewer follows owner
        return request.auth != null && isFollower(request.auth.uid, owner);
      }
    }

    // Places: user-created canonical locations for selection/suggestions
    match /places/{placeId} {
      // Anyone can read place suggestions
      allow read: if true;
      // Only authenticated users may create or update places
      allow write: if request.auth != null;
    }

    // Follow Requests security
    // - Only the target user may read/manage their followRequests
    // - Requesters may create a request doc under the target's followRequests but cannot read the collection
    match /users/{targetUid}/followRequests/{requesterUid} {
      allow create: if request.auth != null && request.auth.uid == requesterUid;
      allow read, update, delete: if request.auth != null && request.auth.uid == targetUid;
    }

    // Optional followers subcollection guard: only the target may write their own followers
    match /users/{targetUid}/followers/{followerUid} {
      allow read: if false; // followers list is not publicly readable in this app
      allow write: if request.auth != null && request.auth.uid == targetUid;
    }

    // Default: keep existing rules for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


